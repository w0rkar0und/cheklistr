{
	"appId": "com.cheklistr.app",
	"appName": "Cheklistr",
	"webDir": "dist",
	"plugins": {
		"Camera": {
			"presentationStyle": "popover"
		},
		"SplashScreen": {
			"launchShowDuration": 0,
			"autoHide": true
		}
	},
	"ios": {
		"contentInset": "automatic"
	},
	"android": {
		"backgroundColor": "#F8FAFC"
	},
	"packageClassList": [
		"BiometricAuthNative",
		"AppPlugin",
		"CAPCameraPlugin",
		"GeolocationPlugin",
		"CAPNetworkPlugin",
		"PreferencesPlugin"
	]
}
