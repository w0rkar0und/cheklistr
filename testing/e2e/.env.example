## Cheklistr E2E Test Environment
## --------------------------------
## Copy this file to .env and fill in the values.

# Vercel deployment URL (no trailing slash)
BASE_URL=https://your-cheklistr-deployment.vercel.app

# Supabase project (defaults to production if omitted)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Test user credentials (site_manager role)
TEST_USER_ID=
TEST_USER_PASSWORD=

# Admin credentials (leave blank to skip admin tests)
ADMIN_USER_ID=
ADMIN_USER_PASSWORD=
