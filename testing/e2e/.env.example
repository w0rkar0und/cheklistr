## Cheklistr E2E Test Environment
## --------------------------------
## Copy this file to .env and fill in the values.

# Vercel deployment URL (no trailing slash)
BASE_URL=https://your-cheklistr-deployment.vercel.app

# Test user credentials (site_manager role)
TEST_USER_ID=
TEST_USER_PASSWORD=

# Admin credentials (leave blank to skip admin tests)
ADMIN_USER_ID=
ADMIN_USER_PASSWORD=
